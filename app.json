{
  "expo": {
    "name": "Voxel Garden Viewer",
    "slug": "voxel-garden-viewer",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "voxelgarden",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E6F4EA"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anywhere.voxelgardenviewer",
      "infoPlist": {
        "NSBonjourServices": [
          "_http._tcp."
        ],
        "NSLocalNetworkUsageDescription": "Voxel Garden Viewer uses the local network to host a model upload and management API on your LAN."
      }
    },
    "android": {
      "package": "com.anywhere.voxelgardenviewer",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4EA",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "ACCESS_WIFI_STATE",
        "CHANGE_WIFI_MULTICAST_STATE"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset"
    ]
  }
}
